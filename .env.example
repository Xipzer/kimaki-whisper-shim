# Kimaki Whisper Shim config (copy to .env)

# Port the shim listens on. Kimaki points OPENAI_BASE_URL here.
SHIM_PORT=7070

# Local Whisper backend (OpenAI-compatible /v1/audio/transcriptions).
#
#   Same machine as the shim ...... http://localhost:8000/v1
#   Whisper on another host ........ http://<whisper-host-ip>:8000/v1
#
# Example split setup: shim runs in WSL2, speaches runs on the Windows GPU
# host — from WSL2 you must use the host's LAN IP, NOT localhost.
WHISPER_BASE_URL=http://localhost:8000/v1

# Whisper model id.
#   speaches / faster-whisper ...... Systran/faster-whisper-large-v3
#   whisper.cpp server ............. whisper-1  (value ignored, field required)
WHISPER_MODEL=Systran/faster-whisper-large-v3

# API key for the Whisper backend (speaches / whisper.cpp usually need none).
WHISPER_API_KEY=none

# Language hint forwarded to Whisper. "" = autodetect.
WHISPER_LANGUAGE=

# Optional shared secret. If set, the shim requires Kimaki's OPENAI_API_KEY to
# equal this exact value. "" = accept any bearer token (fine for localhost).
SHIM_API_KEY=

# debug | info | error
SHIM_LOG_LEVEL=info
