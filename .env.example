# Kimaki Whisper Shim config (copy to .env)

# Port the shim listens on
SHIM_PORT=7070

# Local Whisper backend (speaches) OpenAI-compatible base URL.
# speaches runs on Windows GPU (4070 Super) at port 8000.
# From WSL, use the Windows host LAN IP (NOT localhost).
WHISPER_BASE_URL=http://192.168.1.140:8000/v1

# Whisper model id (speaches uses HF ids). large-v3 = best quality.
WHISPER_MODEL=Systran/faster-whisper-large-v3

# speaches usually needs no key
WHISPER_API_KEY=none

# "" = autodetect language
WHISPER_LANGUAGE=

# Optional: require Kimaki's OPENAI_API_KEY to equal this. "" = accept anything.
SHIM_API_KEY=

SHIM_LOG_LEVEL=info
